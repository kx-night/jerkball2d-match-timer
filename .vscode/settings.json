{
  "dotnet.inlayHints.enableInlayHintsForParameters": true,
  "dotnet.inlayHints.enableInlayHintsForLiteralParameters": true,
  "dotnet.inlayHints.enableInlayHintsForIndexerParameters": true,
  "dotnet.inlayHints.enableInlayHintsForImplicitObjectCreation": true,
  "dotnet.inlayHints.enableInlayHintsForTypes": true,
  "dotnet.codeLens.enableReferencesCodeLens": true,
  "dotnet.codeLens.enableTestsCodeLens": true,
  "csharp.referencesCodeLens.enabled": true,
  "csharp.testsCodeLens.enabled": true,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "dotnet-test-explorer.autoRunTests": false,
  "explorer.compactFolders": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.cs": "$(capture).Designer.cs, $(capture).g.cs",
    "*.csproj": "*.user, *.nuget.g.props, *.nuget.g.targets, launchSettings.json"
  },
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.git": true,
    "**/.DS_Store": true,
    "**/.vscode": false
  },
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.git": true,
    "**/.DS_Store": true
  }
}