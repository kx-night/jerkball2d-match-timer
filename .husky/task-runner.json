{
  "tasks": [
    {
      "name": "dotnet-format-staged",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "format",
        "Jerkball2D.MatchTimer.slnx",
        "--no-restore",
        "--include",
        "${staged}"
      ],
      "include": [
        "**/*.cs"
      ]
    },
    {
      "name": "dotnet-test",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "test",
        "Jerkball2D.MatchTimer.slnx",
        "--no-build",
        "--verbosity",
        "minimal"
      ],
      "include": [
        "src/**/*.Tests.csproj",
        "src/**/*.Test.fsproj"
      ]
    },
    {
      "name": "validate-commit-message",
      "group": "commit-msg",
      "command": "dotnet",
      "args": [
        "tools/CommitMessageValidator/CommitMessageValidator.dll",
        "--commit-msg",
        "${commitMsg}"
      ],
      "include": [
        "tools/CommitMessageValidator/CommitMessageValidator.dll"
      ]
    }
  ]
}
