{
  "tasks": [
    {
      "name": "dotnet-format-staged",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [ "format", "--no-restore", "--include", "${staged}" ],
      "include": [ "**/*.cs" ]
    },
    {
      "name": "dotnet-test",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [ "test", "--no-build", "--verbosity", "minimal" ],
      "include": [
        "src/Core/**/*.csproj",
        "src/Extensions/**/*.fsproj",
        "src/Diagnostics/**/*.csproj"
      ]
    }
  ]
}
